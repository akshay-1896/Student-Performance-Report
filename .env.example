# Student Performance Predictor - Environment Variables
# ======================================================
# Copy this file to .env and fill in your values

# MongoDB Configuration
# Get this from MongoDB Atlas (free tier)
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/StudentPerformance

# AWS Configuration
# Create IAM user with S3 permissions
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# Optional: S3 Bucket Name (must already exist)
# MODEL_BUCKET_NAME=student-performance-mlopsproj